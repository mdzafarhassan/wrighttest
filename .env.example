# ─── Ports ─────────────────────────────────────────
FRONTEND_PORT=5173
BACKEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
VNC_PORT=5900
NOVNC_PORT=6080

# ─── Database ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:${POSTGRES_PORT}/playwright_testing

# ─── Redis ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── App ────────────────────────────────────────────
NODE_ENV=production
FRONTEND_URL=http://localhost:${FRONTEND_PORT}
FRONTEND_DEV_URL=http://localhost:5173
VITE_BACKEND_URL=http://localhost:${BACKEND_PORT}
VITE_NOVNC_URL=http://localhost:${NOVNC_PORT}
VITE_ENABLE_NOVNC=true
WEBHOOK_SECRET=your-secret-here

# ─── Auth ───────────────────────────────────────────
ADMIN_EMAIL=admin@wrighttest.app
ADMIN_PASSWORD=changeme
JWT_SECRET=replace-this-with-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=24h

# ─── Artifacts ──────────────────────────────────────
SCREENSHOTS_DIR=./screenshots
TRACES_DIR=./traces
