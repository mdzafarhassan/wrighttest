# ─── Ports ─────────────────────────────────────────
# Local dev ports
FRONTEND_PORT=5173
BACKEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
VNC_PORT=5900
NOVNC_PORT=6080

# Published host ports for Docker / VPS deployments
FRONTEND_HOST_PORT=5173
BACKEND_HOST_PORT=3000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
VNC_HOST_PORT=5900
NOVNC_HOST_PORT=6080

# ─── Database ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:${POSTGRES_PORT}/playwright_testing

# ─── Redis ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── App ────────────────────────────────────────────
# Local dev:
#   VITE_NOVNC_URL=http://localhost:6080
# Server behind reverse proxy:
#   VITE_NOVNC_URL=/vnc
NODE_ENV=production
FRONTEND_URL=http://localhost:${FRONTEND_HOST_PORT}
FRONTEND_DEV_URL=http://localhost:5173
# Comma-separated extra browser origins allowed by backend CORS.
# Example for ngrok frontend tunnel: FRONTEND_ORIGINS=https://your-frontend.ngrok-free.app
FRONTEND_ORIGINS=
VITE_BACKEND_URL=http://localhost:${BACKEND_HOST_PORT}
VITE_NOVNC_URL=http://localhost:${NOVNC_HOST_PORT}
FRONTEND_INTERNAL_URL=http://localhost:${FRONTEND_PORT}
VITE_ENABLE_NOVNC=true
WEBHOOK_SECRET=your-secret-here

# ─── Auth ───────────────────────────────────────────
ADMIN_EMAIL=admin@wrighttest.app
ADMIN_PASSWORD=changeme
JWT_SECRET=replace-this-with-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=24h

# ─── Artifacts ──────────────────────────────────────
SCREENSHOTS_DIR=./screenshots
TRACES_DIR=./traces
