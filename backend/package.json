{
  "name": "backend",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "prisma:generate": "dotenv -e ../.env -- prisma generate",
    "prisma:studio": "dotenv -e ../.env -- prisma studio",
    "test:trace": "dotenv -e ../.env -- tsx --test tests/failed-run-trace.test.ts",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@playwright/test": "1.61.0",
    "@prisma/client": "^6.19.3",
    "adm-zip": "^0.5.16",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.4",
    "dotenv": "^16.4.7",
    "dotenv-expand": "^12.0.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "playwright": "1.61.0",
    "prisma": "^6.19.3",
    "ts-node-dev": "^2.0.0",
    "uuid": "^11.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
